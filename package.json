{
  "name": "yarn-plugin-min-versions",
  "version": "0.1.0",
  "description": "A Yarn 4 plugin that enforces graph-wide minimum package versions during resolution.",
  "license": "MIT",
  "main": "./sources/index.ts",
  "files": [
    "bundles",
    "sources",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@yarnpkg/cli": "^4.14.1",
    "@yarnpkg/core": "^4.7.0",
    "@yarnpkg/fslib": "^3.1.5",
    "@yarnpkg/plugin-npm": "^3.5.0",
    "clipanion": "^4.0.0-rc.2",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@yarnpkg/builder": "^4.2.3",
    "@yarnpkg/cli-dist": "^4.14.1",
    "rimraf": "5.0.0",
    "tar-stream": "^3.1.8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "build": "builder build plugin",
    "build:dev": "builder build plugin --no-minify",
    "clean": "rimraf bundles .vitest-tmp",
